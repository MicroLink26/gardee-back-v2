PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URL=mongodb+srv://...

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
ACCESS_TTL_MINUTES=15
REFRESH_TTL_DAYS=30

# Email OVH
MAIL_USER=noreply@gardee.fr
MAIL_PASS=
MAIL_FROM="Gardee <noreply@gardee.fr>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# URLs
APP_URL=https://account.gardee.fr
FRONT_URL=https://gardee.fr

# Cron
CRON_SECRET=change_me_cron

# Geocoding
NOMINATIM_USER_AGENT=gardee/2.0
NOMINATIM_EMAIL=contact@gardee.fr

# Resend cooldown (ms)
RESEND_COOLDOWN_MS=600000
